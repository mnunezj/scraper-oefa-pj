{
  "name": "scraper-challenge",
  "version": "1.0.0",
  "description": "Scraper en TypeScript para sitios JSF/PrimeFaces (OEFA / Poder Judicial Perú). Sin automatización de navegador: solo HTTP + parsing.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "scrape": "ts-node src/index.ts",
    "retry-failed": "ts-node src/index.ts --retry-failed",
    "test": "ts-node tests/parsing.test.ts"
  },
  "keywords": ["scraper", "typescript", "jsf", "primefaces", "axios", "cheerio"],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.7",
    "axios-cookiejar-support": "^5.0.5",
    "cheerio": "^1.0.0",
    "tough-cookie": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
